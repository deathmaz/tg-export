<!DOCTYPE html>
<html>
<head>
 <meta charset="utf-8">
 <title>{{ channel_name }} - Exported Data</title>
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <link href="../../css/style.css" rel="stylesheet">
 <script src="../../js/script.js" type="text/javascript"></script>
</head>
<body onload="CheckLocation();">
 <div class="page_wrap">
  <div class="page_header">
   <div class="content">
    <div class="text bold">
     <a href="../../export_results.html">Exported Data</a> / {{ channel_name }}
    </div>
   </div>
  </div>
  <div class="page_body chat_page">
   <div class="history">
{% for item in message_groups %}
{% if item is mapping and item.type == 'date_separator' %}
    <div class="message service">
     <div class="body details">
      {{ item.date }}
     </div>
    </div>
{% elif item is mapping and item.type == 'service' %}
    <div class="message service" id="message{{ item.id }}">
     <div class="body details">
      {{ item.text }}
     </div>
    </div>
{% else %}
    <div class="message default clearfix{% if item.joined %} joined{% endif %}" id="message{{ item.message.id }}">
{% if not item.joined %}
     <div class="pull_left userpic_wrap">
      <div class="userpic {{ item.userpic_color_class }}" style="width: 42px; height: 42px">
       <div class="initials" style="line-height: 42px">{{ item.initials }}</div>
      </div>
     </div>
{% endif %}
     <div class="body">
      <div class="pull_right date details" title="{{ item.message.date_full }}">{{ item.message.date_short }}</div>
{% if not item.joined %}
      <div class="from_name" >
       {{ item.message.sender_name }}{% if item.message.signature %} ({{ item.message.signature }}){% endif %}
      </div>
{% endif %}
{% if item.message.forwarded_from %}
      <div class="forwarded body">
       Forwarded from {{ item.message.forwarded_from }}
      </div>
{% endif %}
{% if item.message.reply_to_id %}
      <div class="reply_to details">
       <a href="#message{{ item.message.reply_to_id }}">In reply to this message</a>
      </div>
{% endif %}
{% if item.message.media_html %}
      {{ item.message.media_html }}
{% endif %}
{% if item.message.text_html %}
      <div class="text">
       {{ item.message.text_html }}
      </div>
{% endif %}
{% if item.message.views is not none %}
      <div class="details">
       {{ item.message.views }} views
      </div>
{% endif %}
{% if item.message.reactions %}
      <span class="reactions">
{% for reaction in item.message.reactions %}
       <span class="reaction"><span class="emoji">{{ reaction.emoji }}</span> <span class="count">{{ reaction.count }}</span></span>
{% endfor %}
      </span>
{% endif %}
     </div>
    </div>
{% endif %}
{% endfor %}
   </div>
  </div>
{% if pagination.has_prev or pagination.has_next %}
  <div class="page_nav">
{% if pagination.has_prev %}
   <a class="block_link" href="{{ pagination.prev_url }}">&larr; Newer messages</a>
{% endif %}
{% if pagination.has_next %}
   <a class="block_link" href="{{ pagination.next_url }}">Older messages &rarr;</a>
{% endif %}
  </div>
{% endif %}
 </div>
</body>
</html>
