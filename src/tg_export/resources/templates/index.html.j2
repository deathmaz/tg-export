<!DOCTYPE html>
<html>
<head>
 <meta charset="utf-8">
 <title>Exported Data</title>
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <link href="css/style.css" rel="stylesheet">
 <script src="js/script.js" type="text/javascript"></script>
</head>
<body onload="CheckLocation();">
 <div class="page_wrap">
  <div class="page_header">
   <div class="content">
    <div class="text bold">Exported Data</div>
   </div>
  </div>
  <div class="page_body">
   <div class="entry_list">
    <div class="entry_head">
     <div class="text bold">Chats</div>
    </div>
{% for channel in channels %}
    <a class="entry block_link clearfix" href="chats/chat_{{ channel.id }}/messages.html">
     <div class="pull_left userpic_wrap">
      <div class="userpic userpic{{ (channel.id % 8) + 1 }}" style="width: 42px; height: 42px">
       <div class="initials" style="line-height: 42px">{{ channel.title[0] if channel.title else '?' }}</div>
      </div>
     </div>
     <div class="body">
      <div class="pull_right info details">{{ channel.message_count }} messages</div>
      <div class="text bold">{{ channel.title }}</div>
{% if channel.username %}
      <div class="details">@{{ channel.username }}</div>
{% endif %}
     </div>
    </a>
{% endfor %}
   </div>
  </div>
 </div>
</body>
</html>
